{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bibo",
  "version": "0.1.0",
  "identifier": "com.bibo.client",
  "build": {
    "beforeDevCommand": "cd ../bibo-webapp && pnpm run dev -- --host",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../bibo-webapp && pnpm run build:tauri",
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Bibo",
        "width": 1200,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "homepage": "https://biboshu.com",
    "shortDescription": "Bibo Official App",
    "license": "AGPL-3.0-or-later",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzNTYzMUEzNzFGQjIwQTQKUldTa0lQdHhvekZXZzdSY0FpRUt3SUZWRFFKelVNYjAxckVvbFFFZEJURnpXeHI4SXc2VldCR1gK",
      "endpoints": [
        "https://github.com/biboshu/bibo-app/releases/latest/download/latest.json"
      ]
    }
  }
}
